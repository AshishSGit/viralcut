{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "aptPkgs": ["ffmpeg", "python3", "python3-pip"]
        },
        "install": {
          "cmds": ["npm ci", "pip install yt-dlp --break-system-packages"]
        },
        "build": {
          "cmds": ["npm run build", "which yt-dlp || pip install yt-dlp --break-system-packages"]
        }
      }
    }
  }
}
